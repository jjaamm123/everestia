# Server
PORT=5000
NODE_ENV=development

# MongoDB — local or Atlas connection string
MONGODB_URI=mongodb://127.0.0.1:27017/everestia_ventures

# Frontend origin (comma-separated for multiple)
CLIENT_URL=http://127.0.0.1:5500,http://localhost:5500,file://

# SMTP (Nodemailer) — e.g. Gmail App Password, SendGrid, Mailgun
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=ventureseverestiallc@gmail.com
SMTP_PASS=your_app_password_here

# Email identities
MAIL_FROM="Everestia Ventures LLC" <ventureseverestiallc@gmail.com>
ADMIN_EMAIL=ventureseverestiallc@gmail.com

# Optional: protect /api/admin/* routes (leave empty to disable in dev)
ADMIN_API_KEY=change_me_to_a_long_random_string
